<?xml version="1.0" encoding="UTF-8"?>
<configuration>

  <property name="SERVICE_NAME" value="backend" />
  <springProperty scope="context" name="ROOT_LOG_LEVEL" source="logging.level.root" defaultValue="INFO" />
  <springProperty scope="context" name="APP_LOG_LEVEL" source="logging.level.com.etftracker.backend" defaultValue="INFO" />

  <springProfile name="local">
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
      <encoder>
        <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{36} - %msg%n</pattern>
      </encoder>
    </appender>

    <logger name="com.etftracker.backend" level="${APP_LOG_LEVEL}" />

    <root level="${ROOT_LOG_LEVEL}">
      <appender-ref ref="CONSOLE" />
    </root>
  </springProfile>

  <springProfile name="!local">
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
      <encoder class="net.logstash.logback.encoder.LogstashEncoder">
        <customFields>{"service":"${SERVICE_NAME}"}</customFields>
      </encoder>
    </appender>

    <logger name="com.etftracker.backend" level="${APP_LOG_LEVEL}" />

    <root level="${ROOT_LOG_LEVEL}">
      <appender-ref ref="CONSOLE" />
    </root>
  </springProfile>

</configuration>
