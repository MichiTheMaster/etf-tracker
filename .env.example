MYSQL_DATABASE=etftracker
MYSQL_USER=etfuser
MYSQL_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-root-me
JWT_SECRET=change-me-very-long-random-secret
APP_CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:3000,http://127.0.0.1:3000,http://localhost,http://127.0.0.1
APP_COOKIE_SECURE=false
APP_PUBLIC_BASE_URL=http://localhost:3000
APP_EMAIL_VERIFICATION_REQUIRED=false
APP_EMAIL_VERIFICATION_TOKEN_VALID_HOURS=24
APP_MAIL_FROM=no-reply@etf-tracker.local
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true
# Für HTTPS/Internet-Betrieb:
# APP_CORS_ALLOWED_ORIGIN_PATTERNS=https://DEIN-NAME.myfritz.net
